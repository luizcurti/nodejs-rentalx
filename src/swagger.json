{
  "openapi": "3.0.0",
  "info": {
    "title": "RentX Documentation",
    "description": "Car rental API",
    "version": "1.0.0",
    "contact": {
      "email": "luiz.curti@gmail.com"
    }
  },
  "paths": {
    "/sessions": {
      "post": {
        "tags": ["Session"],
        "summary": "Authenticate user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "example": "admin@rentalx.com" },
                  "password": { "type": "string", "example": "admin" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authenticated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "user": {
                      "type": "object",
                      "properties": {
                        "name": { "type": "string" },
                        "email": { "type": "string" }
                      }
                    },
                    "token": { "type": "string" },
                    "refresh_token": { "type": "string" }
                  }
                }
              }
            }
          },
          "400": { "description": "Email or password incorrect" }
        }
      }
    },
    "/refresh-token": {
      "post": {
        "tags": ["Session"],
        "summary": "Renew access token",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "token": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Token renewed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": { "type": "string" },
                    "refresh_token": { "type": "string" }
                  }
                }
              }
            }
          },
          "400": { "description": "Invalid or expired refresh token" }
        }
      }
    },
    "/users": {
      "post": {
        "tags": ["Users"],
        "summary": "Create user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/definitions/CreateUser" }
            }
          }
        },
        "responses": {
          "201": { "description": "User created" },
          "400": { "description": "User already exists" }
        }
      }
    },
    "/users/profile": {
      "get": {
        "tags": ["Users"],
        "summary": "Return authenticated user profile",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "User profile",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" },
                    "name": { "type": "string" },
                    "email": { "type": "string" },
                    "driver_license": { "type": "string" },
                    "avatar": { "type": "string" },
                    "avatar_url": { "type": "string", "nullable": true }
                  }
                }
              }
            }
          },
          "401": { "description": "Unauthenticated" },
          "404": { "description": "User not found" }
        }
      }
    },
    "/users/avatar": {
      "patch": {
        "tags": ["Users"],
        "summary": "Update user avatar",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "avatar": { "type": "string", "format": "binary" }
                }
              }
            }
          }
        },
        "responses": {
          "204": { "description": "Avatar updated" },
          "400": { "description": "File not provided" },
          "401": { "description": "Unauthenticated" }
        }
      }
    },
    "/password/forgot": {
      "post": {
        "tags": ["Password"],
        "summary": "Send password recovery email",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email"],
                "properties": {
                  "email": { "type": "string", "example": "user@example.com" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Email sent (or silently ignored if email not registered)" }
        }
      }
    },
    "/password/reset": {
      "post": {
        "tags": ["Password"],
        "summary": "Reset password",
        "parameters": [
          {
            "name": "token",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["password"],
                "properties": {
                  "password": { "type": "string", "example": "newPassword123" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Password reset successfully" },
          "400": { "description": "Invalid or expired token" }
        }
      }
    },
    "/categories": {
      "post": {
        "tags": ["Category"],
        "summary": "Create category",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "description"],
                "properties": {
                  "name": { "type": "string", "example": "SUV" },
                  "description": { "type": "string", "example": "SUV category" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Category created" },
          "400": { "description": "Category already exists" },
          "401": { "description": "Unauthenticated" },
          "403": { "description": "No permission (not admin)" }
        }
      },
      "get": {
        "tags": ["Category"],
        "summary": "List categories",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 20 } }
        ],
        "responses": {
          "200": {
            "description": "Category list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": { "type": "string" },
                      "name": { "type": "string" },
                      "description": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/categories/import": {
      "post": {
        "tags": ["Category"],
        "summary": "Import categories via CSV",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": { "type": "string", "format": "binary" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Categories imported" },
          "400": { "description": "File not provided" },
          "401": { "description": "Unauthenticated" },
          "403": { "description": "No permission" }
        }
      }
    },
    "/specifications": {
      "post": {
        "tags": ["Specifications"],
        "summary": "Create specification",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/definitions/Specification" }
            }
          }
        },
        "responses": {
          "201": { "description": "Specification created" },
          "400": { "description": "Specification already exists" },
          "401": { "description": "Unauthenticated" },
          "403": { "description": "No permission" }
        }
      },
      "get": {
        "tags": ["Specifications"],
        "summary": "List specifications",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 20 } }
        ],
        "responses": {
          "200": {
            "description": "Specification list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/definitions/Specification" }
                }
              }
            }
          }
        }
      }
    },
    "/cars": {
      "post": {
        "tags": ["Cars"],
        "summary": "Create car",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/definitions/Car" }
            }
          }
        },
        "responses": {
          "201": { "description": "Car created", "content": { "application/json": { "schema": { "$ref": "#/definitions/CarResponse" } } } },
          "400": { "description": "Car already exists (duplicate plate)" },
          "401": { "description": "Unauthenticated" },
          "403": { "description": "No permission" }
        }
      }
    },
    "/cars/available": {
      "get": {
        "tags": ["Cars"],
        "summary": "List available cars",
        "parameters": [
          { "name": "brand", "in": "query", "schema": { "type": "string" } },
          { "name": "name", "in": "query", "schema": { "type": "string" } },
          { "name": "category_id", "in": "query", "schema": { "type": "string" } },
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 20 } }
        ],
        "responses": {
          "200": {
            "description": "Available cars list",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/definitions/CarResponse" } }
              }
            }
          }
        }
      }
    },
    "/cars/specifications/{id}": {
      "post": {
        "tags": ["Cars"],
        "summary": "Add specifications to a car",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["specifications_id"],
                "properties": {
                  "specifications_id": {
                    "type": "array",
                    "items": { "type": "string" },
                    "example": ["uuid-spec-1", "uuid-spec-2"]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Specifications added", "content": { "application/json": { "schema": { "$ref": "#/definitions/CarResponse" } } } },
          "400": { "description": "Car not found" },
          "401": { "description": "Unauthenticated" },
          "403": { "description": "No permission" }
        }
      }
    },
    "/cars/images/{id}": {
      "post": {
        "tags": ["Cars"],
        "summary": "Upload car images",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "images": {
                    "type": "array",
                    "items": { "type": "string", "format": "binary" }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Images uploaded" },
          "401": { "description": "Unauthenticated" },
          "403": { "description": "No permission" }
        }
      }
    },
    "/rentals": {
      "post": {
        "tags": ["Rentals"],
        "summary": "Create rental",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["car_id", "expected_return_date"],
                "properties": {
                  "car_id": { "type": "string", "example": "uuid-of-car" },
                  "expected_return_date": { "type": "string", "format": "date-time", "example": "2026-03-15T12:00:00Z" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Rental created" },
          "400": { "description": "Car unavailable or user already has an active rental" },
          "401": { "description": "Unauthenticated" }
        }
      }
    },
    "/rentals/devolution/{id}": {
      "patch": {
        "tags": ["Rentals"],
        "summary": "Return rented car",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "Return completed with calculated total" },
          "400": { "description": "Rental not found" },
          "401": { "description": "Unauthenticated" },
          "403": { "description": "Rental does not belong to the user" }
        }
      }
    },
    "/rentals/user": {
      "get": {
        "tags": ["Rentals"],
        "summary": "List rentals for authenticated user",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 20 } }
        ],
        "responses": {
          "200": {
            "description": "User rental list",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/definitions/RentalResponse" } }
              }
            }
          },
          "401": { "description": "Unauthenticated" }
        }
      }
    }
  },
  "definitions": {
    "CreateUser": {
      "type": "object",
      "required": ["name", "email", "password", "driver_license"],
      "properties": {
        "name": { "type": "string", "example": "John Smith" },
        "email": { "type": "string", "example": "john@email.com" },
        "password": { "type": "string", "example": "password123" },
        "driver_license": { "type": "string", "example": "CNH-12345" }
      }
    },
    "Specification": {
      "type": "object",
      "required": ["name", "description"],
      "properties": {
        "name": { "type": "string", "example": "Air Conditioning" },
        "description": { "type": "string", "example": "Car with air conditioning" }
      }
    },
    "Car": {
      "type": "object",
      "required": ["name", "description", "daily_rate", "license_plate", "fine_amount", "brand", "category_id"],
      "properties": {
        "name": { "type": "string", "example": "Onix" },
        "description": { "type": "string", "example": "Economy car" },
        "daily_rate": { "type": "number", "example": 100 },
        "license_plate": { "type": "string", "example": "ABC-1234" },
        "fine_amount": { "type": "number", "example": 50 },
        "brand": { "type": "string", "example": "Chevrolet" },
        "category_id": { "type": "string", "example": "uuid-of-category" }
      }
    },
    "CarResponse": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "daily_rate": { "type": "number" },
        "available": { "type": "boolean" },
        "license_plate": { "type": "string" },
        "fine_amount": { "type": "number" },
        "brand": { "type": "string" },
        "category_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "RentalResponse": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "car_id": { "type": "string" },
        "user_id": { "type": "string" },
        "start_date": { "type": "string", "format": "date-time" },
        "end_date": { "type": "string", "format": "date-time", "nullable": true },
        "expected_return_date": { "type": "string", "format": "date-time" },
        "total": { "type": "number", "nullable": true },
        "created_at": { "type": "string", "format": "date-time" }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}
