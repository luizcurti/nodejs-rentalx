# Application
APP_API_URL=http://localhost:3333
APP_CORS_ORIGIN=http://localhost:3000

# JWT — REQUIRED: generate with: node -e "require('crypto').randomBytes(64).toString('hex') |& cat"
JWT_SECRET_TOKEN=
JWT_SECRET_REFRESH_TOKEN=
JWT_EXPIRES_IN_TOKEN=15m
JWT_EXPIRES_IN_REFRESH_TOKEN=30d
JWT_EXPIRES_REFRESH_TOKEN_DAYS=30

# Password reset
FORGOT_MAIL_URL=http://localhost:3000/password/reset?token=

# Redis (rate limiter)
REDIS_HOST=localhost
REDIS_PORT=6379

# Storage: "local" | "s3"
disk=local
AWS_BUCKET_URL=

# Mail (ethereal for dev, smtp for prod)
MAIL_HOST=smtp.ethereal.email
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
