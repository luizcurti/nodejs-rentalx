{
  "info": {
    "_postman_id": "rentalx-api-collection",
    "name": "RentalX API",
  "description": "Collection of requests to test the RentalX API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
  "name": "Authentication",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@rentalx.com\",\n  \"password\": \"admin\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/sessions",
          "host": ["{{baseUrl}}"],
          "path": ["sessions"]
        }
      },
      "response": [
        {
          "name": "Example response",
          "originalRequest": {},
          "status": "OK",
          "code": 200,
          "body": "{\n  \"user\": {\n    \"id\": \"uuid\",\n    \"name\": \"Admin\",\n    \"email\": \"admin@rentalx.com\"\n  },\n  \"token\": \"jwt_token\",\n  \"refresh_token\": \"jwt_refresh_token\"\n}"
        }
      ]
    },
    {
  "name": "Create Category",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"SUV\",\n  \"description\": \"Categoria SUV\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/categories",
          "host": ["{{baseUrl}}"],
          "path": ["categories"]
        }
      },
      "response": [
        {
          "name": "Example response",
          "originalRequest": {},
          "status": "Created",
          "code": 201,
          "body": "Category created successfully."
        }
      ]
    },
    {
  "name": "List Categories",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/categories",
          "host": ["{{baseUrl}}"],
          "path": ["categories"]
        }
      },
      "response": [
        {
          "name": "Example response",
          "originalRequest": {},
          "status": "OK",
          "code": 200,
          "body": "[\n  {\n    \"id\": \"uuid\",\n    \"name\": \"SUV\",\n    \"description\": \"SUV Category\"\n  }\n]"
        }
      ]
    },
    {
  "name": "Create Car",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Onix\",\n  \"description\": \"Carro econômico\",\n  \"daily_rate\": 100,\n  \"license_plate\": \"ABC-1234\",\n  \"fine_amount\": 50,\n  \"brand\": \"Chevrolet\",\n  \"category_id\": \"{{category_id}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/cars",
          "host": ["{{baseUrl}}"],
          "path": ["cars"]
        }
      },
      "response": [
        {
          "name": "Example response",
          "originalRequest": {},
          "status": "Created",
          "code": 201,
          "body": "Car created successfully."
        }
      ]
    },
    {
  "name": "Send Forgot Password Email",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"usuario@teste.com\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/password/forgot",
          "host": ["{{baseUrl}}"],
          "path": ["password", "forgot"]
        }
      },
      "response": [
        {
          "name": "Example response",
          "originalRequest": {},
          "status": "OK",
          "code": 200,
          "body": "Recovery email sent successfully."
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3333" },
    { "key": "token", "value": "" },
    { "key": "category_id", "value": "" }
  ]
}
